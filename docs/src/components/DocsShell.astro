---
import { docsRoutes, withBase } from '../lib/site';
import { normalizeBase } from '../lib/base';

const rawBase = import.meta.env.BASE_URL;
const base = normalizeBase(rawBase);
const { title, eyebrow = 'Astro docs', lede } = Astro.props;
---
<section class="docs-layout">
  <aside class="docs-sidebar" aria-label="Docs navigation">
    <p class="eyebrow">Docs section</p>
    <nav>
      {docsRoutes.map((route) => <a href={withBase(base, route.href)}>{route.label}</a>)}
    </nav>
  </aside>
  <article class="docs-article">
    <header class="docs-hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      {lede && <p class="lede">{lede}</p>}
    </header>
    <slot />
  </article>
</section>
