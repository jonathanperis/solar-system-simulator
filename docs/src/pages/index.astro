---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrbitInstrument from '../components/OrbitInstrument.astro';
import TelemetryRail from '../components/TelemetryRail.astro';
import EvidenceLedger from '../components/EvidenceLedger.astro';
import { normalizeBase } from '../lib/base';
import { currentMilestone, repoUrl } from '../lib/site';
import { implementedBodies } from '../lib/bodies';

const base = normalizeBase(import.meta.env.BASE_URL);
---
<BaseLayout>
  <section class="hero gravimetry-hero">
    <div class="hero-copy">
      <p class="eyebrow">Spectral orbit laboratory · C11 · SI-state under glass</p>
      <h1>Gravity as a measured signal.</h1>
      <p class="lede">
        A spectral orbit darkroom for people who want the constants, vectors, source files,
        and browser artifact in the same field of view.
      </p>
      <div class="actions">
        <a class="button" href="#play">Run orbit chamber</a>
        <a class="button-secondary" href={`${base}docs/`}>Open source atlas</a>
        <a class="button-tertiary" href={repoUrl}>Inspect the C code</a>
      </div>
      <div class="status-strip spectral-status" aria-label="Current simulator status">
        <span>{currentMilestone.language} physics core</span>
        <span>{currentMilestone.integrator}</span>
        <span>{currentMilestone.units}</span>
        <span>{implementedBodies.length} traced bodies</span>
        <span>rendering is projection</span>
      </div>
    </div>
    <OrbitInstrument />
  </section>

  <TelemetryRail />

  <section class="lab-section maker-note field-principle" aria-labelledby="maker-note-title">
    <div>
      <p class="eyebrow">Core principle</p>
      <h2 id="maker-note-title">The math is a specimen. The visuals are the microscope.</h2>
    </div>
    <p>
      Physics state stays in meters, kilograms, seconds, vectors, acceleration, and tests. The site now behaves
      like a darkroom for orbital data: spectral traces, specimen ledgers, control notes, and source citations
      reveal where the renderer starts interpreting the model for human eyes.
    </p>
  </section>

  <section class="lab-section split-section" id="play">
    <div class="section-heading field-console-copy">
      <p class="eyebrow">Playable artifact</p>
      <h2>Run the real C/raylib chamber, then interrogate the projection.</h2>
      <p>
        This iframe is not a mock display. It is the checked WebAssembly build from the pipeline. Toggle scale,
        chase bodies, zoom the camera, and compare every readable visual decision with the docs that name the compromise.
      </p>
      <div class="control-note field-controls" aria-label="Simulator controls">
        <strong>Control register</strong>
        <span>Tab/C focus body</span>
        <span>V scale mode</span>
        <span>Mouse wheel zoom</span>
        <span>Full-run trails</span>
      </div>
    </div>
    <figure class="wasm-card science-frame browser-bench">
      <div class="wasm-status-bar">
        <span>Artifact manifest: HTML + JS + WASM</span>
        <a href={`${base}wasm/solar-system-simulator.html`}>Open full demo</a>
      </div>
      <iframe title="Solar System Simulator WebAssembly demo" src={`${base}wasm/solar-system-simulator.html`} loading="lazy"></iframe>
      <figcaption>
        A browser-safe lab instrument with source-backed controls, explicit boot artifacts, and trails that keep recording during long runs.
      </figcaption>
    </figure>
  </section>

  <section class="lab-section truth-split proof-pair" aria-label="Physics and rendering boundary">
    <article>
      <p class="eyebrow">Specimen state</p>
      <h2>Reality lives in <code>src/sim</code></h2>
      <p><code>a = G * source_mass / distance^3 * displacement</code></p>
      <p>Double-precision positions, velocities, masses, and radii stay in physical units. The math gets tests before it gets a glow.</p>
    </article>
    <article>
      <p class="eyebrow">Projection optics</p>
      <h2>The renderer is a calibrated interpretation</h2>
      <p>Illustrative scale, readable moon separation, labels, focus, and sampled trails are visual grammar, not physics mutations.</p>
      <a href={`${base}docs/simulation-core/`}>Trace the simulation core</a>
    </article>
  </section>

  <section class="lab-section equation-tape" aria-labelledby="equation-tape-title">
    <p class="eyebrow">Lab rules</p>
    <h2 id="equation-tape-title">Source-backed orbital data, spectral traces, no galaxy wallpaper.</h2>
    <div class="scribble-grid" aria-label="Scientific design notes">
      <span>Δt stays visible</span>
      <span>Moons keep parents</span>
      <span>Projection admits scale</span>
      <span>Tests guard orbit math</span>
    </div>
  </section>

  <section class="lab-section body-manifest" aria-labelledby="manifest-title">
    <div class="section-heading">
      <p class="eyebrow">Specimen register</p>
      <h2 id="manifest-title">Eight bodies traced as source-backed records.</h2>
      <p>Each implemented body carries identity and parent metadata so docs, renderer, labels, and tests talk about the same simulated object.</p>
    </div>
    <div class="body-table body-table-specimens" role="table" aria-label="Implemented simulator bodies">
      {implementedBodies.map((body) => (
        <a href={`${base}body-catalog/`} class={`body-row accent-${body.accent}`} role="row">
          <strong role="cell">{body.name}</strong>
          <span role="cell">{body.kind}</span>
          <span role="cell">Parent: {body.parent}</span>
          <em role="cell">{body.initialization}</em>
        </a>
      ))}
    </div>
  </section>

  <section class="lab-section rough-edges field-principle" aria-labelledby="rough-edges-title">
    <div>
      <p class="eyebrow">Field log</p>
      <h2 id="rough-edges-title">Precise, playable, unfinished in public.</h2>
    </div>
    <ul>
      <li>Working now: Sun, Mercury, Venus, Earth, Moon, Mars, Phobos, Deimos, focus cycling, zoom, scale modes, and full-run trail history.</li>
      <li>Still missing by choice: outer planets, textures, shaders, ephemeris-accurate state vectors, and barycentric Sun motion.</li>
      <li>Next additions stay scientific: one body or rendering improvement per iteration, with tests and docs updated beside the code.</li>
    </ul>
  </section>

  <EvidenceLedger />
</BaseLayout>
