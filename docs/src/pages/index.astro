---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrbitInstrument from '../components/OrbitInstrument.astro';
import TelemetryRail from '../components/TelemetryRail.astro';
import EvidenceLedger from '../components/EvidenceLedger.astro';
import { normalizeBase } from '../lib/base';
import { currentMilestone, repoUrl } from '../lib/site';
import { implementedBodies } from '../lib/bodies';

const base = normalizeBase(import.meta.env.BASE_URL);
---
<BaseLayout>
  <section class="hero chaos-lab-hero">
    <div class="hero-copy">
      <p class="eyebrow">Orbital mechanics club · C11 · browser lab bench</p>
      <h1>Gravity, but make it a weird science poster.</h1>
      <p class="lede">
        A loud little physics site for the kind of person who wants the orbit trails, the constants,
        the source files, and the browser build all on the same messy desk.
      </p>
      <div class="actions">
        <a class="button" href="#play">Launch the specimen</a>
        <a class="button-secondary" href={`${base}docs/`}>Read the notebook</a>
        <a class="button-tertiary" href={repoUrl}>Open the source drawer</a>
      </div>
      <div class="status-strip lab-sticker-wall" aria-label="Current simulator status">
        <span>{currentMilestone.language}</span>
        <span>{currentMilestone.rendering}</span>
        <span>{currentMilestone.integrator}</span>
        <span>{implementedBodies.length} bodies under glass</span>
        <span>math receipts included</span>
      </div>
    </div>
    <OrbitInstrument />
  </section>

  <TelemetryRail />

  <section class="lab-section maker-note zine-note" aria-labelledby="maker-note-title">
    <div>
      <p class="eyebrow">Core principle</p>
      <h2 id="maker-note-title">The simulator is honest. The website is allowed to be unhinged.</h2>
    </div>
    <p>
      Physics state stays clean: meters, kilograms, seconds, vectors, acceleration. The page behaves like a
      photocopied science zine found inside a planetarium backpack: bright labels, hand-built diagrams,
      source citations, and no corporate galaxy wallpaper.
    </p>
  </section>

  <section class="lab-section split-section" id="play">
    <div class="section-heading field-console-copy">
      <p class="eyebrow">Playable specimen</p>
      <h2>Run the real C/raylib artifact, then interrogate it.</h2>
      <p>
        This iframe is not concept art. It is the checked WebAssembly build from the pipeline. Toggle scale,
        chase bodies, zoom the camera, and compare the visual cheats with the code notes that admit every compromise.
      </p>
      <div class="control-note control-note-young" aria-label="Simulator controls">
        <strong>Control cheat sheet</strong>
        <span>Tab/C focus body</span>
        <span>V scale mode</span>
        <span>Mouse wheel zoom</span>
        <span>Sampled long trails</span>
      </div>
    </div>
    <figure class="wasm-card science-frame browser-bench">
      <div class="wasm-status-bar">
        <span>Artifact manifest: HTML + JS + WASM</span>
        <a href={`${base}wasm/solar-system-simulator.html`}>Open full demo</a>
      </div>
      <iframe title="Solar System Simulator WebAssembly demo" src={`${base}wasm/solar-system-simulator.html`} loading="lazy"></iframe>
      <figcaption>
        A browser-safe lab instrument with source-backed controls, explicit boot artifacts, and trails that stay performant deep into long runs.
      </figcaption>
    </figure>
  </section>

  <section class="lab-section truth-split proof-pair" aria-label="Physics and rendering boundary">
    <article>
      <p class="eyebrow">The non-negotiable bit</p>
      <h2>Reality lives in <code>src/sim</code></h2>
      <p><code>a = G * source_mass / distance^3 * displacement</code></p>
      <p>Double-precision positions, velocities, masses, and radii stay in physical units. The math gets tests before it gets applause.</p>
    </article>
    <article>
      <p class="eyebrow">The theatrical bit</p>
      <h2>The renderer gets a hall pass</h2>
      <p>Illustrative scale, readable moon separation, labels, focus, and sampled trails are visual grammar, not physics mutations.</p>
      <a href={`${base}docs/simulation-core/`}>Trace the simulation core</a>
    </article>
  </section>

  <section class="lab-section equation-tape" aria-labelledby="equation-tape-title">
    <p class="eyebrow">Lab wall slogans</p>
    <h2 id="equation-tape-title">Young nerd energy, source-backed science, zero stock-space fog.</h2>
    <div class="scribble-grid" aria-label="Scientific design notes">
      <span>Δt is visible</span>
      <span>Moons know their parents</span>
      <span>Renderer lies in public</span>
      <span>Tests guard the orbit math</span>
    </div>
  </section>

  <section class="lab-section body-manifest" aria-labelledby="manifest-title">
    <div class="section-heading">
      <p class="eyebrow">Specimen tray</p>
      <h2 id="manifest-title">Eight bodies pinned, labeled, and still moving.</h2>
      <p>Each implemented body carries identity and parent metadata so docs, renderer, labels, and tests talk about the same thing.</p>
    </div>
    <div class="body-table body-table-personality" role="table" aria-label="Implemented simulator bodies">
      {implementedBodies.map((body) => (
        <a href={`${base}body-catalog/`} class={`body-row accent-${body.accent}`} role="row">
          <strong role="cell">{body.name}</strong>
          <span role="cell">{body.kind}</span>
          <span role="cell">Parent: {body.parent}</span>
          <em role="cell">{body.initialization}</em>
        </a>
      ))}
    </div>
  </section>

  <section class="lab-section rough-edges zine-note" aria-labelledby="rough-edges-title">
    <div>
      <p class="eyebrow">Field report</p>
      <h2 id="rough-edges-title">Readable, playable, unfinished on purpose.</h2>
    </div>
    <ul>
      <li>Working now: Sun, Mercury, Venus, Earth, Moon, Mars, Phobos, Deimos, focus cycling, zoom, scale modes, and bounded long-run trail rendering.</li>
      <li>Still missing by choice: outer planets, textures, shaders, ephemeris-accurate state vectors, and barycentric Sun motion.</li>
      <li>Next additions stay scientific: one body or rendering improvement per iteration, with tests and docs updated beside the code.</li>
    </ul>
  </section>

  <EvidenceLedger />
</BaseLayout>
