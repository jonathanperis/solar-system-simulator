---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrbitInstrument from '../components/OrbitInstrument.astro';
import TelemetryRail from '../components/TelemetryRail.astro';
import EvidenceLedger from '../components/EvidenceLedger.astro';
import { normalizeBase } from '../lib/base';
import { currentMilestone, repoUrl } from '../lib/site';
import { implementedBodies } from '../lib/bodies';

const base = normalizeBase(import.meta.env.BASE_URL);
---
<BaseLayout>
  <section class="hero observatory-hero personality-hero">
    <div class="hero-copy">
      <p class="eyebrow">C lab notebook · orbital mechanics · tiny moons</p>
      <h1>Newtonian space toys for people who read the source.</h1>
      <p class="lede">
        A young, nerdy solar-system lab where the fun part is visible: SI units, kick-drift-kick stepping,
        parent-relative moons, readable trails, and a C/raylib build that boots in the browser.
      </p>
      <div class="actions">
        <a class="button" href="#play">Boot the lab</a>
        <a class="button-secondary" href={`${base}docs/`}>Open the field notes</a>
        <a class="button-tertiary" href={repoUrl}>Inspect the C</a>
      </div>
      <div class="status-strip lab-sticker-wall" aria-label="Current simulator status">
        <span>{currentMilestone.language}</span>
        <span>{currentMilestone.rendering}</span>
        <span>{currentMilestone.integrator}</span>
        <span>{implementedBodies.length} bodies now</span>
        <span>no magic numbers without receipts</span>
      </div>
    </div>
    <OrbitInstrument />
  </section>

  <TelemetryRail />

  <section class="lab-section maker-note zine-note" aria-labelledby="maker-note-title">
    <div>
      <p class="eyebrow">Why this exists</p>
      <h2 id="maker-note-title">For the kid who paused a space video to ask, “but what is it calculating?”</h2>
    </div>
    <p>
      The simulator keeps the physical state boring and honest: meters, kilograms, seconds, vectors,
      accelerations. The page gets to be weirder. It labels the compromises, shows the artifacts,
      and turns the codebase into a public science notebook instead of a sleepy project README.
    </p>
  </section>

  <section class="lab-section split-section" id="play">
    <div class="section-heading field-console-copy">
      <p class="eyebrow">Browser bench</p>
      <h2>Run the actual C/raylib build, then poke the knobs.</h2>
      <p>
        The embedded app is the WebAssembly artifact from the pipeline. Use it like a desktop planetarium
        hacked into a school lab cart: switch scale modes, focus bodies, zoom, and compare the visible view
        with the docs that explain what the renderer is bending.
      </p>
      <div class="control-note control-note-young" aria-label="Simulator controls">
        <strong>Lab controls</strong>
        <span>Tab/C focus body</span>
        <span>V scale mode</span>
        <span>Mouse wheel zoom</span>
        <span>Trails stay awake</span>
      </div>
    </div>
    <figure class="wasm-card science-frame browser-bench">
      <div class="wasm-status-bar">
        <span>Artifact manifest: HTML + JS + WASM</span>
        <a href={`${base}wasm/solar-system-simulator.html`}>Open full demo</a>
      </div>
      <iframe title="Solar System Simulator WebAssembly demo" src={`${base}wasm/solar-system-simulator.html`} loading="lazy"></iframe>
      <figcaption>
        Not a movie. A readable instrument with debug-friendly overlays, source-backed controls, and browser-safe boot checks.
      </figcaption>
    </figure>
  </section>

  <section class="lab-section truth-split proof-pair" aria-label="Physics and rendering boundary">
    <article>
      <p class="eyebrow">Physics state</p>
      <h2>Reality stays in the sim core</h2>
      <p><code>a = G * source_mass / distance^3 * displacement</code></p>
      <p>Double-precision positions, velocities, masses, and radii stay in physical units inside <code>src/sim</code>.</p>
    </article>
    <article>
      <p class="eyebrow">Rendered view</p>
      <h2>The picture gets artist privileges</h2>
      <p>Illustrative scale, moon separation, labels, camera focus, and trails are renderer choices, not changes to simulation state.</p>
      <a href={`${base}docs/simulation-core/`}>Trace the simulation core</a>
    </article>
  </section>

  <section class="lab-section equation-tape" aria-labelledby="equation-tape-title">
    <p class="eyebrow">Desk scribbles</p>
    <h2 id="equation-tape-title">The vibe is science-fair poster, not corporate space stock.</h2>
    <div class="scribble-grid" aria-label="Scientific design notes">
      <span>Δt stays explicit</span>
      <span>Moon orbits parent first</span>
      <span>Renderer lies only for readability</span>
      <span>Tests guard the math</span>
    </div>
  </section>

  <section class="lab-section body-manifest" aria-labelledby="manifest-title">
    <div class="section-heading">
      <p class="eyebrow">Body manifest</p>
      <h2 id="manifest-title">Eight bodies in the jar, each with a parent tag.</h2>
      <p>Moons are initialized relative to their parent body, then released into the same shared gravity simulation.</p>
    </div>
    <div class="body-table body-table-personality" role="table" aria-label="Implemented simulator bodies">
      {implementedBodies.map((body) => (
        <a href={`${base}body-catalog/`} class={`body-row accent-${body.accent}`} role="row">
          <strong role="cell">{body.name}</strong>
          <span role="cell">{body.kind}</span>
          <span role="cell">Parent: {body.parent}</span>
          <em role="cell">{body.initialization}</em>
        </a>
      ))}
    </div>
  </section>

  <section class="lab-section rough-edges zine-note" aria-labelledby="rough-edges-title">
    <div>
      <p class="eyebrow">Current state</p>
      <h2 id="rough-edges-title">Alive, honest, and still growing.</h2>
    </div>
    <ul>
      <li>Working now: Sun, Mercury, Venus, Earth, Moon, Mars, Phobos, Deimos, focus cycling, zoom, scale modes, and persistent trails.</li>
      <li>Still intentionally missing: outer planets, textures, shaders, ephemeris-accurate state vectors, and barycentric Sun motion.</li>
      <li>Next steps stay small: one body or rendering improvement per iteration, with tests and docs updated beside the code.</li>
    </ul>
  </section>

  <EvidenceLedger />
</BaseLayout>
