---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrbitInstrument from '../components/OrbitInstrument.astro';
import TelemetryRail from '../components/TelemetryRail.astro';
import EvidenceLedger from '../components/EvidenceLedger.astro';
import { normalizeBase } from '../lib/base';
import { currentMilestone, repoUrl } from '../lib/site';
import { implementedBodies } from '../lib/bodies';

const base = normalizeBase(import.meta.env.BASE_URL);
---
<BaseLayout>
  <section class="hero observatory-hero">
    <div class="hero-copy">
      <p class="eyebrow">Physics-first C/raylib observatory</p>
      <h1>Solar mechanics, exposed like an instrument.</h1>
      <p class="lede">
        A small C11 and raylib lab for inspecting Newtonian gravity, SI-unit state, parent-relative moons,
        and the code boundaries that keep rendering honest.
      </p>
      <div class="actions">
        <a class="button" href="#play">Run WebAssembly lab</a>
        <a class="button-secondary" href={`${base}docs/`}>Open Astro docs</a>
        <a class="button-tertiary" href={repoUrl}>Read C source</a>
      </div>
      <div class="status-strip" aria-label="Current simulator status">
        <span>{currentMilestone.language}</span>
        <span>{currentMilestone.rendering}</span>
        <span>{currentMilestone.integrator}</span>
        <span>{implementedBodies.length} bodies</span>
      </div>
    </div>
    <OrbitInstrument />
  </section>

  <TelemetryRail />

  <section class="lab-section split-section" id="play">
    <div class="section-heading">
      <p class="eyebrow">Browser simulator</p>
      <h2>Run the same C app in the public lab bench.</h2>
      <p>
        The iframe below loads the Emscripten artifact published by the Build workflow. If the browser canvas is still booting,
        use the surrounding telemetry and direct artifact links to confirm the runtime path.
      </p>
    </div>
    <figure class="wasm-card science-frame">
      <div class="wasm-status-bar">
        <span>Artifact set: HTML + JS + WASM</span>
        <a href={`${base}wasm/solar-system-simulator.html`}>Open full demo</a>
      </div>
      <iframe title="Solar System Simulator WebAssembly demo" src={`${base}wasm/solar-system-simulator.html`} loading="lazy"></iframe>
      <figcaption>
        Loading should show an explicit runtime shell. A blank canvas is treated as a diagnostic state, not as acceptable site polish.
      </figcaption>
    </figure>
  </section>

  <section class="lab-section equation-band" aria-label="Physics notes">
    <div>
      <p class="eyebrow">Physics notebook</p>
      <h2>State stays physical. Views stay negotiable.</h2>
    </div>
    <p><code>a = G * source_mass / distance^3 * displacement</code></p>
    <a href={`${base}docs/simulation-core/`}>Trace the simulation core</a>
  </section>

  <section class="lab-section body-manifest" aria-labelledby="manifest-title">
    <div class="section-heading">
      <p class="eyebrow">Mission manifest</p>
      <h2 id="manifest-title">Current bodies in the scene</h2>
    </div>
    <div class="body-chip-row">
      {implementedBodies.map((body) => <a href={`${base}body-catalog/`} class={`body-chip ${body.accent}`}>{body.name}<span>{body.kind}</span></a>)}
    </div>
  </section>

  <EvidenceLedger />
</BaseLayout>
