---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocsShell from '../../components/DocsShell.astro';
import { currentMilestone, docsManualGroups, docsRoutes, repoUrl, withBase } from '../../lib/site';
import { normalizeBase } from '../../lib/base';

const base = normalizeBase(import.meta.env.BASE_URL);
const totalRoutes = docsRoutes.length;
const firstRoute = docsRoutes.find((route) => route.href === 'docs/architecture/') ?? docsRoutes[0];
const wasmRoute = withBase(base, 'wasm/solar-system-simulator.html');
---
<BaseLayout title="Orbit manual">
  <DocsShell
    eyebrow="Orbit manual / cartoon cockpit"
    title="Trace every orbit wire without one giant scroll."
    lede="Use the docs like a service bay for the cartoon cockpit: start with source boundaries, inspect gravity and rendering, then verify controls, WebAssembly, and the roadmap."
  >
    <section class="manual-hero" aria-label="Orbit manual summary">
      <div class="manual-hero-copy">
        <p class="eyebrow">SERVICE MANUAL / SCIENCE CLUB BACKPLANE</p>
        <h2>Open the simulator like a cabinet.</h2>
        <p>
          Every route answers one maintainer question: where the physics lives, what the renderer bends for readability, how the browser bundle is produced, and what work is still intentionally unfinished.
        </p>
        <div class="manual-chip-row" aria-label="Manual diagnostics">
          <span>{totalRoutes} focused orbit routes</span>
          <span>{currentMilestone.language} + raylib</span>
          <span>{currentMilestone.units}</span>
          <span>WASM lab bench</span>
        </div>
        <div class="manual-actions" aria-label="Primary manual actions">
          <a class="button" href={withBase(base, firstRoute.href)}>Start with architecture</a>
          <a class="button button-secondary" href={wasmRoute}>Launch WASM cockpit</a>
        </div>
      </div>
      <aside class="manual-stats" aria-label="Documentation stats">
        <p>ROUTES</p>
        <strong>{totalRoutes}</strong>
        <span>FOCUSED MANUAL PAGES</span>
        <dl>
          {docsManualGroups.map((group) => (
            <>
              <dt>{group.title}</dt>
              <dd>{group.routes.length}</dd>
            </>
          ))}
        </dl>
      </aside>
    </section>

    <section class="manual-routes" aria-labelledby="manual-routes-title">
      <p class="eyebrow">Solar manual routes</p>
      <h2 id="manual-routes-title">Pick a route by job, not by scroll depth.</h2>
      <div class="manual-route-grid">
        {docsManualGroups.map((group) => (
          <article class="manual-route-card" data-doc-group>
            <p>{group.id}</p>
            <h3>{group.title}</h3>
            <span class="manual-card-rule" aria-hidden="true"></span>
            <p>{group.description}</p>
            <div class="manual-route-links">
              {group.routes.map((route) => (
                <a
                  class="manual-route-link"
                  href={withBase(base, route.href)}
                  data-doc-route={`${route.code} ${route.label} ${route.summary} ${group.title}`}
                >
                  <span>{route.code}</span>
                  <strong>{route.label}</strong>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="manual-index" aria-labelledby="manual-index-title">
      <div class="manual-index-heading">
        <div>
          <p class="eyebrow">Full index</p>
          <h2 id="manual-index-title">Every orbit manual page</h2>
        </div>
        <a href={repoUrl}>Open source →</a>
      </div>
      <div class="manual-index-list">
        {docsRoutes.map((route, index) => (
          <a
            class="manual-index-row"
            href={withBase(base, route.href)}
            data-doc-route={`${route.code} ${route.label} ${route.summary}`}
          >
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{route.label}</strong>
            <em>{route.summary}</em>
          </a>
        ))}
      </div>
    </section>
  </DocsShell>
</BaseLayout>
