---
import FooterCredits from '../components/FooterCredits.astro';
import { primaryRoutes, siteName, withBase } from '../lib/site';
import { normalizeBase } from '../lib/base';

const rawBase = import.meta.env.BASE_URL;
const base = normalizeBase(rawBase);
const title = Astro.props.title ? `${Astro.props.title} · ${siteName}` : siteName;
const description = 'A physics-first C and raylib solar-system lab with a browser WebAssembly demo and source-backed Astro docs.';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@10..48,500;10..48,700;10..48,800&family=Recursive:CASL,MONO,wght@0.6,1,500;0.8,1,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <div class="stars" aria-hidden="true"></div>
    <div class="orbital-grid" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href={base} aria-label="Solar System Simulator home">
        <span class="brand-mark">☉</span>
        <span>{siteName}</span>
      </a>
      <nav class="primary-nav" aria-label="Main navigation">
        {primaryRoutes.map((route) => <a href={withBase(base, route.href)}>{route.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <FooterCredits />
  </body>
</html>
